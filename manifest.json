{
  "manifest_version": 3,
  "name": "LuckyOnAir",
  "version": "1.1",
  "description": "chzzk IU 김러끼의 유튜브업로드와  치지직 방송알림을 확인을 하십시오(각오함)",
  "permissions": ["notifications", "alarms", "storage"],
  "host_permissions": [
    "https://api.chzzk.naver.com/*",
    "https://www.youtube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  }
}
