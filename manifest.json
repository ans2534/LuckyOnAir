{
  "manifest_version": 3,
  "name": "러끼 방송 알람",
  "version": "1.1",
  "description": "chzzk IU 김러끼(각오함)",
  "permissions": ["notifications", "alarms", "storage"],
  "host_permissions": [
    "https://api.chzzk.naver.com/*",
    "https://www.youtube.com/*",
    "https://apis.naver.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  }
}
